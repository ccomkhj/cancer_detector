Bootstrap: docker
From: pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

%labels
    Author MRI Segmentation Team
    Version 1.0
    Description MRI 2.5D Segmentation Training Container

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export PYTHONPATH="/workspace:${PYTHONPATH}"

%files
    requirements.txt /app/requirements.txt
    mri /app/mri
    service /app/service
    tools /app/tools

%post
    # Install system dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        git \
        curl \
        vim \
        && rm -rf /var/lib/apt/lists/*

    # Upgrade pip and install Python dependencies
    pip install --no-cache-dir --upgrade pip
    pip install --no-cache-dir -r /app/requirements.txt

    # Create runtime directories with proper permissions
    mkdir -p /app/checkpoints /app/logs /app/.aim /workspace
    chmod -R 777 /app/checkpoints /app/logs /app/.aim /workspace

%runscript
    cd /workspace
    exec python service/train.py "$@"
