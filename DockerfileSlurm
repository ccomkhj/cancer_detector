# MRI Segmentation Training Container (HPC/SLURM-friendly)
#
# Key differences vs Dockerfile:
# - Makes common output dirs writable for non-root runtimes (HPC containers often run rootless)
# - Uses ENTRYPOINT so you can pass train.py args directly (works well with sbatch/srun)
#
# Example:
#   docker build -f DockerfileSlurm -t mri-train:slurm .
#   docker run --rm --gpus all -v $PWD/data:/app/data:ro -v $PWD/checkpoints:/app/checkpoints mri-train:slurm --config config.yaml

FROM pytorch/pytorch:2.1.0-cuda12.1-cudnn8-runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    WANDB_API_KEY="" \
    WANDB_SILENT=true

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    curl \
    vim \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

COPY . .

# Ensure common runtime output locations are writable when the container runs rootless.
RUN mkdir -p /app/checkpoints /app/logs /app/.aim && \
    chmod -R a+rwx /app/checkpoints /app/logs /app/.aim

ENTRYPOINT ["python", "/app/service/train.py"]
CMD ["--config", "config.yaml"]

